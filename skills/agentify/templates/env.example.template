# === {{ identity.name }} — variabili ambiente ===
# Copia in .env e compila i valori. NON committare il file .env.

# --- LLM API keys (per i modelli scelti nel manifesto) ---
{% if 'claude-' in (models.roles.values() | map(attribute='default') | join(',')) %}ANTHROPIC_API_KEY=
{% endif %}{% if 'gemini-' in (models.roles.values() | map(attribute='default') | join(',')) %}GEMINI_API_KEY=
{% endif %}{% if 'deepseek-' in (models.roles.values() | map(attribute='default') | join(',')) %}DEEPSEEK_API_KEY=
{% endif %}{% if 'gpt-' in (models.roles.values() | map(attribute='default') | join(',')) %}OPENAI_API_KEY=
{% endif %}

# --- AgentOS runtime ---
AGENTOS_HOST=localhost
AGENTOS_PORT=7777
AGENTOS_DB_PATH=data/agent_memory.db

# --- Telegram bot (opzionale) ---
# Crea un bot via @BotFather su Telegram (/newbot), copia qui il token.
# Se valorizzato:
#   - main.py attiva l'interface Telegram nativa di Agno (modalità webhook, prod)
#   - puoi lanciare anche il polling bot standalone (modalità dev locale, no tunnel)
TELEGRAM_BOT_TOKEN=
# Whitelist user_id Telegram (comma-separated). Vuoto = tutti possono scrivere.
TELEGRAM_ALLOWED_USERS=

