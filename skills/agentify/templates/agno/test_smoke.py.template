"""Smoke test per {{ identity.name }}.

Verifica:
- Manifest carica correttamente
- skill_loader trova le skill
- _models.resolve_model funziona per i provider supportati
- build_team() istanzia il team
"""

from __future__ import annotations
import pytest
import yaml
from pathlib import Path

from agent.skill_loader import load_skills, skills_summary, make_skill_tool
from agent._models import resolve_model

PROJECT_ROOT = Path(__file__).resolve().parent.parent.parent
MANIFEST_PATH = PROJECT_ROOT / "agent" / "agent.yaml"


def test_manifest_loads():
    with open(MANIFEST_PATH, encoding="utf-8") as f:
        manifest = yaml.safe_load(f)
    assert manifest["identity"]["name"] == "{{ identity.name }}"
    assert manifest["engine"] == "{{ engine }}"
    {% for role_name in models.roles.keys() %}assert "{{ role_name }}" in manifest["models"]["roles"]
    {% endfor %}


def test_skill_loader():
    skills = load_skills(PROJECT_ROOT / ".claude" / "skills")
    assert len(skills) >= {{ skills.imported | length }}
    summary = skills_summary(skills)
    assert "## Skill disponibili" in summary

    tool = make_skill_tool(skills)
    res = tool("__nonexistent__")
    assert "non trovata" in res


@pytest.mark.parametrize("model_id", [
    {% for role_cfg in models.roles.values() %}"{{ role_cfg.default }}",
    {% endfor %}
])
def test_resolve_model(model_id):
    m = resolve_model(model_id)
    assert m.id == model_id


def test_resolve_model_unknown():
    with pytest.raises(ValueError):
        resolve_model("unknown-foo-bar")


def test_build_team():
    from agent.main import build_team
    team = build_team()
    assert team.name == "{{ identity.name }}"
    expected_members = { {% for r in models.roles.keys() %}{% if r != 'orchestrator' %}"{{ r | capitalize }}", {% endif %}{% endfor %} }
    assert {m.name for m in team.members} == expected_members
