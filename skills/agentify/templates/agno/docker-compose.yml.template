version: "3.9"

services:
  agent:
    build:
      context: ..
      dockerfile: deploy/Dockerfile.agent
    image: {{ identity.name | lower | replace(' ', '-') }}:latest
    container_name: {{ identity.name | lower | replace(' ', '-') }}
    env_file:
      - ../.env
    ports:
      - "7777:7777"
    volumes:
      - ../data:/app/data
      - ../audit_log:/app/audit_log
    restart: unless-stopped

  {% if triggers.schedule %}scheduler:
    image: {{ identity.name | lower | replace(' ', '-') }}:latest
    container_name: {{ identity.name | lower | replace(' ', '-') }}-scheduler
    env_file:
      - ../.env
    volumes:
      - ../data:/app/data
      - ../audit_log:/app/audit_log
    command: ["python", "-m", "agent.workflows.scheduled", "--schedule"]
    depends_on:
      - agent
    restart: unless-stopped
  {% endif %}
